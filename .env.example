# Copy to .env locally if you want live LLM calls.
# Never commit real keys.

ZHIPU_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_API_KEY=replace-with-local-secret
ZHIPU_MODEL=glm-5.1
LLM_TIMEOUT_SECONDS=120

# Optional server settings
CIC_HOST=127.0.0.1
CIC_PORT=8765
CIC_DATA_PATH=data/local_store.json
